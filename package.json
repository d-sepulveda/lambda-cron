{
  "name": "lambda-cron",
  "version": "0.1.0",
  "description": "Lambda Cron - Scheduled Lambda functions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/local/server.ts",
    "dev:sam": "cdk synth --no-staging && sam local start-api -t cdk.out/LambdaCronStack-dev.template.json --warm-containers EAGER",
    "invoke": "cdk synth --no-staging && sam local invoke -t cdk.out/LambdaCronStack-dev.template.json",
    "build": "tsc",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "destroy": "cdk destroy",
    "lint": "eslint src/",
    "test": "jest"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "aws-cdk": "^2.1113.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  }
}
